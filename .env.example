# Teller API Configuration
TELLER_APP_ID=app_pn55bmnf8k4papve7o000
TELLER_CERT_PATH=./certificate.pem
TELLER_KEY_PATH=./private_key.pem
TELLER_ENV=sandbox  # sandbox, development, or production

# Ntropy API (ML Transaction Enrichment)
# Sign up at https://ntropy.com to get an API key
# Ntropy provides merchant recognition and category detection
NTROPY_API_KEY=your_ntropy_api_key_here
USE_NTROPY=false  # Set to true when you have an API key

# Database
DATABASE_URL=sqlite:///./fintrack.db

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_TELLER_APP_ID=app_pn55bmnf8k4papve7o000
NEXT_PUBLIC_TELLER_ENV=sandbox
