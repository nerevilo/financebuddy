# Teller API — get these at https://teller.io
TELLER_APP_ID=app_replace_with_your_own
TELLER_ENV=development          # sandbox | development | production

# Cert paths default to ./certificate.pem and ./private_key.pem.
# Override only if you keep certs elsewhere.
# TELLER_CERT_PATH=./certificate.pem
# TELLER_KEY_PATH=./private_key.pem

# SQLite location. Defaults to ./financebuddy.db.
# FB_DB_PATH=./financebuddy.db
